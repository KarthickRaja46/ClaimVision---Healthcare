{
  "name": "HealthPulse Icon Matched Theme",
  "dataColors": [
    "#0F6CBD",
    "#0A5BA6",
    "#0A2E6E",
    "#00B4D8",
    "#9B59B6",
    "#4DBBDB",
    "#E74856",
    "#16C60C",
    "#F7A52B",
    "#D0DBE8"
  ],
  "background": "#F3F6FA",
  "foreground": "#0F1117",
  "tableAccent": "#0F6CBD",
  "good": "#16C60C",
  "neutral": "#F7A52B",
  "bad": "#E74856",
  "visualStyles": {
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F3F6FA" } },
            "transparency": 0
          }
        ],
        "wallpaper": [
          {
            "color": { "solid": { "color": "#F3F6FA" } },
            "transparency": 0
          }
        ]
      }
    },
    "card": {
      "*": {
        "background": [
          { "color": { "solid": { "color": "#FFFFFF" } }, "transparency": 0 }
        ],
        "title": [
          { "show": false }
        ],
        "calloutValue": [
          {
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold",
            "bold": true,
            "color": { "solid": { "color": "#0A5BA6" } }
          }
        ],
        "categoryLabel": [
          {
            "show": true,
            "color": { "solid": { "color": "#5B6272" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#0A5BA6" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "grid": [
          {
            "gridBorderColor": { "solid": { "color": "#D0DBE8" } },
            "gridBorderWidth": 1
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#0F1117" } },
            "backColor": { "solid": { "color": "#FFFFFF" } },
            "alternateBackColor": { "solid": { "color": "#F0F6FF" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "pivotTable": {
      "*": {
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#0A5BA6" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "rowHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#0A5BA6" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#0F1117" } },
            "backColor": { "solid": { "color": "#FFFFFF" } },
            "alternateBackColor": { "solid": { "color": "#F0F6FF" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    }
  }
}
